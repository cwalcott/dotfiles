# Unix
alias tlf="tail -f"
alias ln='ln -v'
alias mkdir='mkdir -p'
alias ...='../..'
alias l='ls'
alias ll='ls -al'
alias lh='ls -Alh'
alias -g G='| grep'
alias -g M='| less'
alias -g L='| wc -l'
alias -g ONE="| awk '{ print \$1}'"
alias e="$EDITOR"
alias v="$VISUAL"

# git
alias gb='git branch'
alias gd='git diff'
alias gc='git commit -v'
alias gca='git commit -v -a'
alias gco='git checkout'
alias gd='git diff'
alias gs='git status'

# Bundler
alias b="bundle"

# Tests and Specs
alias s="spring rspec"
alias t="spring testunit"

# Xcode
alias podr="rm -rf Pods Podfile.lock ; pod install"

# Other
alias vi='vim'
alias rtps='rake test:parallel_with_specs'
alias history='fc -l 1'

# Node.js
alias tn='node --import=tsx --env-file=.env'
alias m='npx mocha'

# Include custom aliases
[[ -f ~/.aliases.local ]] && source ~/.aliases.local
